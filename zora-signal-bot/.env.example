# ─────────────────────────────────────────────
# Zora Signal Bot — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_ENV=development            # development | staging | production
APP_DEBUG=false
APP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
APP_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS

# ── FastAPI / Server ─────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_WEBHOOK_URL=         # https://yourdomain.com/webhook
TELEGRAM_WEBHOOK_SECRET=      # Random secret for webhook validation
# Comma-separated list of Telegram user IDs allowed to use admin commands
TELEGRAM_ADMIN_USER_IDS=

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=zora_signal
POSTGRES_USER=zora
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://zora:CHANGE_ME@db:5432/zora_signal

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── X / Twitter API ──────────────────────────
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# Polling interval in seconds when not using streaming
X_POLL_INTERVAL_SECONDS=60

# ── Zora ─────────────────────────────────────
# TODO: Replace with actual Zora API base URL when available
ZORA_API_BASE_URL=https://api.zora.co
ZORA_API_KEY=
# Base chain RPC (for on-chain queries if REST unavailable)
BASE_RPC_URL=https://mainnet.base.org

# ── LLM (optional) ───────────────────────────
LLM_ENABLED=false
LLM_PROVIDER=openai            # openai | anthropic
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=2

# ── OpenAI Responses API (Conversational) ────
ENABLE_CONVERSATIONAL_MODE=true
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_RESPONSES_MODEL=gpt-4o-mini
CONVERSATION_TIMEOUT_MINUTES=30

# ── Scoring Thresholds ────────────────────────
SCORE_IGNORE_THRESHOLD=30
SCORE_WATCH_THRESHOLD=50
SCORE_ALERT_THRESHOLD=65
SCORE_PAPER_TRADE_THRESHOLD=75
SCORE_LIVE_TRADE_THRESHOLD=85

# ── Trading — Safety (hard defaults) ─────────
PAPER_TRADING_ENABLED=true
LIVE_TRADING_ENABLED=false     # Must be explicitly set true + /live_on
LIVE_TRADING_REQUIRE_APPROVAL=true
MAX_POSITION_SIZE_USD=100.0
MAX_DAILY_LOSS_USD=500.0
MAX_CONCURRENT_POSITIONS=5
MIN_LIQUIDITY_USD=10000.0
MAX_SLIPPAGE_BPS=200           # 2%
NO_TRADE_AFTER_LAUNCH_SECONDS=300
PAPER_TRADE_SIZE_USD=50.0

# ── Wallet (live trading only — handle with care) ─
WALLET_PRIVATE_KEY=            # NEVER commit; injected at runtime only
WALLET_ADDRESS=
